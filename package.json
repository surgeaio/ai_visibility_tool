{
  "name": "ai_visibility_tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "npm run dev",
    "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "railway": "tsx railway-server.ts",
    "db:seed": "tsx scripts/seed.ts",
