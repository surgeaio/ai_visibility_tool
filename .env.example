# Copy to .env.local — never commit real secrets.

# ============================================
# APP URLS (CRITICAL — must match Vercel domain)
# ============================================
NEXT_PUBLIC_APP_URL=https://ai-visibility-tool-nu.vercel.app
APP_URL=https://ai-visibility-tool-nu.vercel.app

# ============================================
# SUPABASE (Dashboard → Settings → API → Legacy anon + service_role)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://jfunkoftnvbxkmlelkad.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...          # Legacy "anon public" key (JWT)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...              # Legacy "service_role" — SERVER ONLY, never NEXT_PUBLIC_

# ============================================
# CRON (Vercel Cron Jobs — required for daily automation)
# ============================================
CRON_SECRET=your-random-secret-here

# ============================================
# AI PROVIDERS — preferred: single OpenRouter key
# ============================================
# Recommended: one OpenRouter key powers OpenAI, Anthropic, and Gemini models.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional model overrides (defaults: openai/gpt-4o-mini, anthropic/claude-sonnet-4, google/gemini-2.5-pro)
OPENROUTER_MODEL_OPENAI=
OPENROUTER_MODEL_CLAUDE=
OPENROUTER_MODEL_GEMINI=

# Legacy direct-provider keys (only used if OPENROUTER_API_KEY is absent)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Perplexity is not on OpenRouter — keep its own key if you want Perplexity runs
PERPLEXITY_API_KEY=                                # Optional

# ============================================
# SEARCH / SEO
# ============================================
SERPER_API_KEY=...

# ============================================
# GOOGLE OAUTH (Google Cloud Console → Credentials)
# ============================================
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://ai-visibility-tool-nu.vercel.app/api/auth/callback/google

# ============================================
# SECURITY — ENCRYPTION_KEY must be 64 hex chars (openssl rand -hex 32). CRON_SECRET: long random string.
# ============================================
ENCRYPTION_KEY=
CRON_SECRET=

# ============================================
# FEATURE FLAGS
# ============================================
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
STRICT_LLM_EXECUTION=false
AI_DAILY_BUDGET_USD=50
