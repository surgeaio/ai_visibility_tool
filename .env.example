# Copy to .env.local

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# When true, LLM providers throw if keys are missing (no synthetic "Demo …" text). Use in production.
STRICT_LLM_EXECUTION=false

NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Upstash REST (for @upstash/ratelimit — copy from Upstash console “REST API”)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=

# Google OAuth (Search Console) — set redirect to match your app URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# 64-char hex (openssl rand -hex 32). Used to encrypt stored user API keys at rest.
ENCRYPTION_KEY=

CRON_SECRET=

# Serper.dev — Google SERP JSON (https://serper.dev)
SERPER_API_KEY=

AI_DAILY_BUDGET_USD=50
